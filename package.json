{
  "name": "autonomy",
  "version": "1.0.0",
  "description": "Payment infrastructure for AI agents - Like autonomous systems, Autonomy guides AI agents to accomplish their missions in the real world",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "npm run lint && npm run test",
    "docker:build": "docker build -t autonomy .",
    "docker:run": "docker run -p 3000:3000 autonomy",
    "deploy": "npm run build && npm run deploy:railway",
    "deploy:railway": "railway deploy",
    "db:seed": "node scripts/seed-database.js",
    "db:migrate": "node scripts/migrate-database.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "logs": "railway logs",
    "logs:follow": "railway logs --follow",
    "status": "railway status",
    "prod:start": "NODE_ENV=production node server-production.js",
    "prod:logs": "pm2 logs autonomy",
    "prod:restart": "pm2 restart autonomy",
    "prod:stop": "pm2 stop autonomy",
    "prod:status": "pm2 status",
    "backup": "node scripts/backup-database.js",
    "restore": "node scripts/restore-database.js",
    "health": "curl -f http://localhost:3000/health || exit 1",
    "precommit": "npm run lint && npm run test",
    "prepare": "husky install || true",
    "email:test": "node scripts/test-email.js",
    "stripe:test": "node scripts/test-stripe.js",
    "oauth:test": "node scripts/test-oauth.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "stripe": "^14.5.0",
    "nodemailer": "^6.9.7",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "redis": "^4.6.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "joi": "^17.11.0",
    "crypto": "^1.0.1",
    "cookie-parser": "^1.4.6",
    "express-mongo-sanitize": "^2.2.0",
    "xss": "^1.0.14",
    "hpp": "^0.2.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "payments",
    "api",
    "stripe",
    "autonomy",
    "agents",
    "fintech"
  ],
  "author": "Autonomy Technologies",
  "license": "MIT",
  "homepage": "https://autonomypay.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/coltonsakamoto/autonomypay.git"
  },
  "bugs": {
    "url": "https://github.com/coltonsakamoto/autonomypay/issues",
    "email": "support@autonomypay.xyz"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/coltonsakamoto"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
